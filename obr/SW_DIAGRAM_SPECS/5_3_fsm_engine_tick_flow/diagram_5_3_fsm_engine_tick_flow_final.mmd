---
config:
  layout: elk
---
flowchart TD

  subgraph A["1 — začiatok ticku"]
    AUDIO["Kontrola konca audia"]
    VIDEO["Kontrola konca videa"]
    FIN{Scéna skončila?}
    GETSTATE["Načítanie aktuálneho stavu"]
  end

  subgraph B["2 — globálne udalosti"]
    GLOB["Vyhodnotenie globálnych prechodov\npodľa celkového času scény"]
    GCHECK{Globálny prechod\nnájdený?}
    GCHANGE["Zmena stavu\na návrat"]
  end

  subgraph C["3 — lokálne prechody"]
    TL["Časované akcie bežia\nsamostatne na pozadí"]
    LOCAL["Vyhodnotenie lokálnych prechodov podľa času v stave\ntimeout · audioEnd · videoEnd · mqttMessage · always"]
    LCHECK{Lokálny prechod\nnájdený?}
    LCHANGE["Zmena stavu"]
    CONT["Scéna pokračuje\nďalší tick"]
  end

  subgraph D["4 — zmena stavu"]
    EXIT["Vykonanie výstupných akcií"]
    GOTO["Prechod do nového stavu"]
    CLEAR["Vyčistenie čakajúcich udalostí\nMQTT · audioEnd · videoEnd"]
    RESET["Zrušenie starých časovačov"]
    ENTER["Vykonanie vstupných akcií\nnové časovače naplánované"]
  end

  subgraph E["5 — koniec ticku"]
    END["Scéna skončená"]
  end

  AUDIO --> VIDEO --> FIN
  FIN -- áno --> END
  FIN -- nie --> GETSTATE --> GLOB --> GCHECK
  GCHECK -- nie --> TL
  GCHECK -- áno --> GCHANGE --> D
  TL --> LOCAL --> LCHECK
  LCHECK -- nie --> CONT
  LCHECK -- áno --> LCHANGE --> D

  EXIT --> GOTO --> CLEAR --> RESET --> ENTER

  classDef tick fill:#E6F1FB,stroke:#185FA5,color:#0C447C,stroke-width:1.2px,font-size:20px;
  classDef glob fill:#E1F5EE,stroke:#0F6E56,color:#085041,stroke-width:1.2px,font-size:20px;
  classDef local fill:#EEEDFE,stroke:#534AB7,color:#3C3489,stroke-width:1.2px,font-size:20px;
  classDef change fill:#FAEEDA,stroke:#854F0B,color:#633806,stroke-width:1.2px,font-size:20px;
  classDef end_ fill:#FAECE7,stroke:#993C1D,color:#712B13,stroke-width:1.2px,font-size:20px;
  classDef decision fill:#FAEEDA,stroke:#854F0B,color:#633806,stroke-width:1.2px,font-size:20px;

  class AUDIO,VIDEO,GETSTATE tick;
  class GLOB,GCHANGE glob;
  class TL,LOCAL,LCHANGE,CONT local;
  class EXIT,GOTO,CLEAR,RESET,ENTER change;
  class END end_;
  class FIN,GCHECK,LCHECK decision;