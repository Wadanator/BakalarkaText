---
config:
  layout: elk
---
flowchart TD

  subgraph A["1 — štart"]
    START["Spustenie backendu\npríprava základného logovania"]
    INIT["Inicializácia systému\nnačítanie konfigurácie a služieb\nprepojenie komponentov"]
    WEB["Spustenie webového dashboardu\nFlask + SocketIO na pozadí"]
  end

  subgraph B["2 — main loop"]
    CONN["Počiatočné pripojenie na MQTT\nopakované pokusy pri zlyhaní"]
    OFFLINE["Offline režim\nwarning raz, pokračuje bez MQTT"]
    LOOP["Hlavná slučka systému\nkontrola stavu · kontrola tlačidla · čistenie zariadení"]
    SHUT{"Je požadované vypnutie?"}
    CLEAN["Upratanie pri ukončení\nuvoľnenie služieb a parsera\nuloženie štatistík"]
  end

  subgraph C["3 — štart scény"]
    TRIG["Požiadavka na spustenie scény\ntlačidlo / MQTT správa / webové rozhranie"]
    SETSRUN["Nastavenie stavu scény na 'running'\nzamknutie prístupu + zápis stavu"]
    ALREADY["Požiadavka odmietnutá\nscéna už beží"]
    BCASTSTART["Odoslanie aktuálneho stavu\nnotifikácia klientov webového dashboardu"]
    THREAD["Spustenie vlákna na pozadí\n→ logika behu scény"]
  end

  subgraph D["4 — beh scény (vlákno na pozadí)"]
    LOAD["Načítanie scény\nJSON · validácia · oznámenie zmeny stavu"]
    LOADERR["Nastavenie stavu scény na 'idle'\nodoslanie aktualizácie stavu"]
    PRELOAD["Príprava spustenia scény\nzapnutie sledovania spätnej väzby\naudio preload · štart automatu · onEnter akcie"]
    RUNLOOP["Beh scény v slučke\nspracovanie prechodov · čakanie medzi cyklami"]
    ENDSTOP["Záver scény\nvypnutie sledovania a videa\nnastavenie 'idle' + vypnutie zariadení\nodoslanie STOP signálu + aktualizácia stavu"]
  end

  subgraph E["5 — externý stop"]
    STOP["Externé zastavenie scény\nvolané z webového rozhrania"]
    WASTRAN{"Podarilo sa prepnúť\nstav scény na 'idle'?"}
    STOPALL["Zastavenie parsera, audia a videa\nvypnutie zariadení\nodoslanie STOP signálu + aktualizácia stavu"]
    BCASTONLY["Odoslanie aktuálneho stavu\n(scéna nebeží — len notifikácia)"]
  end

  subgraph F["6 — watchdog"]
    FILE["/tmp/museum_scene_state\n'running' / 'idle'"]
    WD["Watchdog kontrola behu scény\nčaká na idle pred reštartom\nstale > 2h = idle"]
  end

  START --> INIT --> WEB --> CONN
  CONN -- "pripojený" --> LOOP
  CONN -- "zlyhanie" --> OFFLINE --> LOOP
  LOOP --> SHUT
  SHUT -- "nie" --> LOOP
  SHUT -- "áno" --> CLEAN

  TRIG --> SETSRUN
  SETSRUN -- "už beží" --> ALREADY
  SETSRUN -- "ok" --> BCASTSTART --> THREAD --> LOAD
  LOAD -- "chyba" --> LOADERR
  LOAD -- "ok" --> PRELOAD --> RUNLOOP --> ENDSTOP

  STOP --> WASTRAN
  WASTRAN -- "nie" --> BCASTONLY
  WASTRAN -- "áno" --> STOPALL

  SETSRUN -. "zápis 'running'" .-> FILE
  ENDSTOP -. "zápis 'idle'" .-> FILE
  FILE -. "číta" .-> WD

  classDef init fill:#E6F1FB,stroke:#185FA5,color:#0C447C,stroke-width:1.2px,font-size:20px;
  classDef loop fill:#E1F5EE,stroke:#0F6E56,color:#085041,stroke-width:1.2px,font-size:20px;
  classDef scene fill:#EEEDFE,stroke:#534AB7,color:#3C3489,stroke-width:1.2px,font-size:20px;
  classDef stop fill:#FAECE7,stroke:#993C1D,color:#712B13,stroke-width:1.2px,font-size:20px;
  classDef decision fill:#FAEEDA,stroke:#854F0B,color:#633806,stroke-width:1.2px,font-size:20px;
  classDef file fill:#F1EFE8,stroke:#5F5E5A,color:#444441,stroke-dasharray:5 5,stroke-width:1.0px,font-size:18px;
  classDef wd fill:#E1F5EE,stroke:#0F6E56,color:#085041,stroke-width:1.2px,font-size:20px;

  class START,INIT,WEB init;
  class CONN,OFFLINE,LOOP,CLEAN loop;
  class TRIG,SETSRUN,BCASTSTART,THREAD,LOAD,PRELOAD,RUNLOOP,ENDSTOP scene;
  class STOP,STOPALL,BCASTONLY,LOADERR stop;
  class SHUT,WASTRAN,ALREADY decision;
  class FILE file;
  class WD wd;